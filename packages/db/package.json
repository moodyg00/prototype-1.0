{
  "name": "@prototype/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./generated/client.ts",
    "./browser": "./generated/browser.ts",
    "./enums": "./generated/enums.ts",
    "./models": "./generated/models.ts",
    "./*": "./generated/*"
  },
  "scripts": {
    "build": "prisma generate",
    "typecheck": "tsc --noEmit",
    "prisma": "prisma",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "create-admin": "node prisma/create-admin-user.mjs"
  },
  "prisma": {
    "config": "prisma.config.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "prisma": "^7.8.0",
    "typescript": "^5.8.3"
  }
}
