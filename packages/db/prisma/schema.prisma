model PasswordReset {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  tokenHash    String    @map("token_hash")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt       DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid
  user         User      @relation("password_resets_user_id_users", fields: [userId], references: [id], onDelete: Cascade)
  createdByRef User?     @relation("password_resets_created_by_users", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByRef User?     @relation("password_resets_updated_by_users", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("password_resets")
}

model UserSession {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  lastSeenAt DateTime? @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  userAgent  String?   @map("user_agent") @db.VarChar(512)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model ChangeLog {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tableName    String    @map("table_name") @db.VarChar(120)
  recordId     String    @map("record_id") @db.Uuid
  action       String /// CHECK action IN ('create', 'update', 'delete', 'automation')
  userId       String?   @map("user_id") @db.Uuid
  changes      Json?     @db.JsonB
  metadata     Json?     @db.JsonB
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid
  user         User?     @relation("change_log_user_id_users", fields: [userId], references: [id], onDelete: SetNull)
  createdByRef User?     @relation("change_log_created_by_users", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByRef User?     @relation("change_log_updated_by_users", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@index([tableName, recordId])
  @@index([userId])
  @@index([createdAt])
  @@map("change_log")
}

model Setting {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  module       String    @db.VarChar(80)
  key          String    @db.VarChar(120)
  value        Json      @db.JsonB
  description  String?
  isSensitive  Boolean   @default(false) @map("is_sensitive")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid
  createdByRef User?     @relation("settings_created_by_users", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByRef User?     @relation("settings_updated_by_users", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@unique([module, key])
  @@index([module])
  @@index([module, key])
  @@map("settings")
}

