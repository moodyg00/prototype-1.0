  createdBy                          String?                  @map("created_by") @db.Uuid
  updatedBy                          String?                  @map("updated_by") @db.Uuid
  createdByRef                       User?                    @relation("users_created_by_users", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByRef                       User?                    @relation("users_updated_by_users", fields: [updatedBy], references: [id], onDelete: SetNull)
  usersAsCreatedBy                   User[]                   @relation("users_created_by_users")
