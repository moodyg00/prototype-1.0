generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

// Connection URL is configured in prisma.config.ts (Prisma 7).
// At runtime, src/lib/prisma.ts instantiates PrismaClient with a
// PrismaPg adapter built from process.env.DATABASE_URL.

model UserRole {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @unique @db.VarChar(80)
  permissions Json      @default("{}") @db.JsonB
  isSystem    Boolean   @default(false) @map("is_system")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  users       User[]

  @@map("user_roles")
}

model User {
