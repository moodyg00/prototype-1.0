{
  "name": "prototype-1.0",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:admin": "pnpm --filter @prototype/admin dev",
    "dev:agent": "pnpm --filter @prototype/agent dev",
    "dev:worker": "pnpm --filter @prototype/worker dev",
    "dev:public": "npx --yes serve apps/public-site/dev -p 8080",
    "dev:public:live": "npx --yes serve apps/public-site/live -p 8081",
    "promote:public": "node scripts/promote-public-site.mjs",
    "hostinger:admin": "pnpm install --frozen-lockfile && pnpm --filter @prototype/admin build",
    "hostinger:agent": "pnpm install --frozen-lockfile && pnpm --filter @prototype/agent build",
    "hostinger:worker": "pnpm install --frozen-lockfile",
    "postinstall": "pnpm --filter @prototype/db prisma:generate",
    "typecheck": "turbo run typecheck",
    "prisma:generate": "pnpm --filter @prototype/db prisma generate"
  },
  "devDependencies": {
    "turbo": "^2.5.6",
    "typescript": "^5.8.3"
  }
}
