{
  "name": "prototype-1.0",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "node scripts/hostinger-build.mjs",
    "dev": "turbo run dev",
    "dev:admin": "pnpm --filter @prototype/admin dev",
    "dev:agent": "pnpm --filter @prototype/agent dev",
    "dev:worker": "pnpm --filter @prototype/worker dev",
    "dev:public-dev": "pnpm --filter @prototype/public-dev dev",
    "dev:public": "npx --yes serve apps/public-site -p 8080",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "dev:chroma": "packages/memory/node_modules/.bin/chroma run --path data/chroma --port 8000",
    "dev:memory-stack": "node scripts/dev-memory-stack.mjs",
    "promote:public": "node scripts/promote-public-site.mjs",
    "start": "node scripts/hostinger-start.mjs",
    "hostinger:admin": "npm exec pnpm -- install --frozen-lockfile && npm run prisma:generate && npm exec pnpm -- --filter @prototype/admin build",
    "hostinger:admin:start": "npm --prefix apps/admin run start",
    "hostinger-start-admin": "node scripts/hostinger-serve-admin.mjs",
    "hostinger:agent": "npm exec pnpm -- install --frozen-lockfile && npm run prisma:generate && npm exec pnpm -- --filter @prototype/agent build",
    "hostinger:agent:start": "npm --prefix apps/agent run start",
    "hostinger-start-agent": "node scripts/hostinger-serve-agent.mjs",
    "hostinger:public-dev": "npm exec pnpm -- install --frozen-lockfile && HOSTINGER_APP=public-dev node scripts/hostinger-build.mjs",
    "hostinger:public-dev:start": "npm --prefix apps/public-dev run start",
    "hostinger-start-public-dev": "node scripts/hostinger-serve-public-dev.mjs",
    "hostinger:worker": "npm exec pnpm -- install --frozen-lockfile && npm run prisma:generate",
    "hostinger:worker:start": "npm --prefix apps/worker run start",
    "postinstall": "node scripts/prisma-generate.mjs",
    "typecheck": "turbo run typecheck",
    "prisma:generate": "node scripts/prisma-generate.mjs"
  },
  "devDependencies": {
    "turbo": "^2.5.6",
    "typescript": "^5.8.3"
  }
}
