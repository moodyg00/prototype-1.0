# Proto-2 Environment
# Copy to `.env.local` for local development.

# =============================================================================
# LOCAL DEV (default — no Supabase required)
# =============================================================================
# Run Postgres locally. Auth is optional in development (admin fallback user).
#
#   cp .env.example .env.local
#   createdb proto2   # if needed
#   pnpm --filter @prototype/db prisma migrate deploy
#   pnpm dev:admin
# =============================================================================

# -----------------------------------------------------------------------------
# Database — Postgres via Prisma (@prototype/db)
# -----------------------------------------------------------------------------
# Local:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/proto2

# Hostinger + Supabase (production — set in hPanel Node app env, not here yet):
# DATABASE_URL=postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_DATABASE_URL=postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:5432/postgres
#
# Legacy aliases still accepted by prisma.config.ts:
# SUPABASE_DB_URL=
# SUPABASE_POOLER_URL=

# -----------------------------------------------------------------------------
# Auth — session cookies (admin + App Lab share in production)
# -----------------------------------------------------------------------------
# Dev: auth gate is OFF unless you set AUTH_REQUIRED=true
AUTH_REQUIRED=false

# Production (Hostinger admin + agent Node apps — same values on both):
# AUTH_REQUIRED=true
# AUTH_SECRET=                         # openssl rand -base64 32
# AUTH_COOKIE_DOMAIN=.yourdomain.com  # leading dot = all subdomains
# AUTH_SESSION_TTL_DAYS=30

# Optional overrides (defaults shown):
# AUTH_COOKIE_NAME=proto_session

# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------
# Admin app public URL (invite links, webhooks bootstrap). No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=Proto-2

# -----------------------------------------------------------------------------
# Media storage
# -----------------------------------------------------------------------------
# Default: local disk at public/uploads (no extra env needed).
# Optional Supabase Storage adapter (NOT auth — files only):
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=media

# -----------------------------------------------------------------------------
# Secrets in database after bootstrap
# -----------------------------------------------------------------------------
# Mercury, OpenAI, SMTP, cron secret → Admin UI or:
#   pnpm --filter @prototype/admin integrations:bootstrap
#
# MERCURY_API_KEY=
# CRON_SECRET=
# OPENAI_API_KEY=
