# Database — local dev (see apps/admin/.env.local; never commit real values)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prototype"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prototype"

# Production Supabase Postgres (host only — no Supabase Auth):
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@[region].pooler.supabase.com:5432/postgres

# Auth — set AUTH_REQUIRED=false locally to skip login
AUTH_REQUIRED=false
AUTH_SECRET=
AUTH_COOKIE_DOMAIN=

# App URL (this app)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Public static site CORS (comma-separated origins for contact form)
PUBLIC_SITE_ORIGINS=http://localhost:8080,http://localhost:8081

# Optional: bootstrap integration secrets into DB (then remove from env)
MERCURY_API_KEY=
