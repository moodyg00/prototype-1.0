# Proto-2 Environment
# Copy to .env.local for local development.

# -----------------------------------------------------------------------------
# Deployment notes
# - Local dev should use `.env.local`.
# - Hostinger production and Hostinger dev/staging should each define their own
#   environment variables in the panel. No code changes are needed to switch.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Database — Postgres connection string consumed by prisma.config.ts and
# the runtime PrismaPg adapter in src/lib/prisma.ts.
# Example for local: postgresql://postgres:postgres@localhost:5432/proto2
# Example for Supabase: postgresql://<user>:<pass>@<host>:6543/postgres?pgbouncer=true&connection_limit=1
# Preferred variable:
#   DATABASE_URL
# Also supported (for host/panel compatibility):
#   SUPABASE_DB_URL or SUPABASE_POOLER_URL
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/proto2
# SUPABASE_DB_URL=
# SUPABASE_POOLER_URL=

# Optional: direct non-pooler URL for manual migration tasks
# (usually port 5432 on Supabase, while pooled URLs commonly use 6543)
# DIRECT_DATABASE_URL=

# -----------------------------------------------------------------------------
# Supabase client keys
# For browser usage, set NEXT_PUBLIC_* values.
# This app also accepts SUPABASE_URL / SUPABASE_ANON_KEY and maps them.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Mercury Bank (server-only — never use NEXT_PUBLIC_ for these)
# -----------------------------------------------------------------------------
# API tokens and webhook secrets live in the database (Admin → API integrations).
# Run once to import legacy values from this file:
#   npm run integrations:bootstrap
# MERCURY_API_KEY=
# MERCURY_WEBHOOK_SECRET=
# MERCURY_API_BASE_URL=https://api.mercury.com/api/v1

# Public base URL for webhooks and shareable links (no trailing slash).
# Stored in DB (system settings) after bootstrap; kept here for first-time import.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron auth secret — stored in DB (system settings) after bootstrap.
# CRON_SECRET=

# -----------------------------------------------------------------------------
# AI / agent runtime
# -----------------------------------------------------------------------------
# OpenAI key is stored in Admin → API integrations (provider: openai).
# OPENAI_API_KEY=

# Tencent memory credentials — stored in Admin → API integrations (provider: tencent).
# TENCENT_API_KEY=
# TENCENT_BASE_URL=

# -----------------------------------------------------------------------------
# Outbound email (website / transactional mail)
# -----------------------------------------------------------------------------
# SMTP and sender identity live in the database (Admin → Settings → Email Provider).
# Run once to import legacy values from this file:
#   npm run integrations:bootstrap
# EMAIL_PROVIDER=smtp
# MAIL_FROM_NAME=Proto-2
# MAIL_FROM_EMAIL=no-reply@yourdomain.com
# MAIL_REPLY_TO=support@yourdomain.com
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USERNAME=no-reply@yourdomain.com
# SMTP_PASSWORD=
# RESEND_API_KEY=
# SENDGRID_API_KEY=
# POSTMARK_API_KEY=

# -----------------------------------------------------------------------------
# App settings
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=Proto-2
