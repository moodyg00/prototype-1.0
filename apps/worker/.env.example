# Worker — HTTP job runner (keeps heavy cron work off admin/agent Next processes)

WORKER_PORT=3003

# Same secret admin expects on /api/cron/* (from DB system settings or bootstrap)
CRON_SECRET=

# Admin app URL — worker delegates jobs here for now
ADMIN_BASE_URL=http://localhost:3001

# Production (optional Hostinger Node app or internal URL):
# ADMIN_BASE_URL=https://admin.yourdomain.com
# CRON_SECRET=<same as admin system settings>
