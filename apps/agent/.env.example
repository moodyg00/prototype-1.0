# Postgres for persisting encrypted credentials and sessions (via Prisma)
# We are sharing the DB with proto-2.
# Copy the value from proto-2/.env.local (currently: postgresql://grant@localhost:5432/proto2?schema=adminagent)
# Using a separate schema (adminagent) so tables don't collide with proto-2's public schema.
DATABASE_URL="postgresql://grant@localhost:5432/proto2?schema=adminagent"

# Optional master passphrase for SecureStore (can also be provided per-run via UI)
# SECURE_PASSPHRASE=your-strong-passphrase-here

# xAI API key for the visual browser operator (and other agents/workflows).
# This is the recommended place for keys (never commit .env.local).
# XAI_API_KEY=xai-your-key-here
# (Fallback to OPENAI_API_KEY also supported in the operator)
