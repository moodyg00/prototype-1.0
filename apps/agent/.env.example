# App Lab (agent) — shares Postgres + session cookies with admin in production.

# Local dev — same database as admin (@prototype/db)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/proto2

# Auth (match admin in production)
AUTH_REQUIRED=false
# AUTH_COOKIE_NAME=proto_session
# AUTH_SECRET=
# AUTH_COOKIE_DOMAIN=.yourdomain.com

NEXT_PUBLIC_APP_URL=http://localhost:3002

# Agent runtime keys (optional in dev)
# XAI_API_KEY=
# SECURE_PASSPHRASE=
