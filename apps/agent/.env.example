# Database (shared with admin)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prototype

# Auth
AUTH_REQUIRED=false

# Grok / xAI — used by workflow LLM/agent nodes and the IDE agent.
# Alternatively, add an active xAI Integration row (provider = 'xai') in the DB.
XAI_API_KEY=

# Anthropic — one API key for all Claude models (Sonnet, Opus, etc.).
# Pass the model id per request; no separate keys per model.
ANTHROPIC_API_KEY=

# OpenAI — GPT-5.1 Codex models for the IDE agent (and memory embeddings when set).
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# IDE agent (public-dev). Optional: pin the workflow id used by /api/ide-agent/run.
# When unset, the route looks the workflow up by name ("IDE Agent Visual").
# IDE_AGENT_WORKFLOW_ID=

# Auto-ingest IDE agent thought traces into memory after each run (default on).
# Set to false to disable.
# IDE_AGENT_INGEST_THOUGHTS=false

# Agent memory (Chroma vector store)
# Omit CHROMA_URL to use in-memory mock store (dev)
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=mhp_memory
# MEMORY_STORE=mock

# Embeddings: stub | xai | openai
MEMORY_EMBED_PROVIDER=stub
# MEMORY_EMBED_MODEL=text-embedding-3-small

# Self-call for LangGraph review ingest (server-side)
# AGENT_INTERNAL_URL=http://127.0.0.1:3002

# Admin bulk ingest → agent Memory API
# AGENT_APP_URL=http://127.0.0.1:3002

# Memory webhook + cron (optional; hooks reject when unset and secret sent)
# MEMORY_WEBHOOK_SECRET=
# MEMORY_CRON_SECRET=