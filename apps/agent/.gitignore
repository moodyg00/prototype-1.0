# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (commit only the example; keep real secrets out)
.env
.env.local
.env.*.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Browser operator config (non-secret model settings only — commit the .example)
# Put real XAI_API_KEY (and other keys for agents/workflows) in .env.local
configs/browser.config.json
configs/browser.config.local.*
*.config.local.*


/lib/generated/prisma
/logs/
/*.log
screenshots/
secure/
vendors/

# On-demand workflow exports (POST /api/workflow/[id]/export, scripts/seed-*.ts).
# These are generated snapshots of whatever is currently in Postgres — checking
# them in makes them silently stale the moment the DB workflow is edited again.
# Treat "export" as a download, not a repo artifact.
/artifacts/workflows/
