# Auth — set AUTH_REQUIRED=false locally to skip login (reuses @prototype/auth)
AUTH_REQUIRED=false
AUTH_SECRET=
AUTH_COOKIE_DOMAIN=

# Database
DATABASE_URL=postgresql://grant@localhost:5432/proto2
DIRECT_DATABASE_URL=postgresql://grant@localhost:5432/proto2

# This app name and URL
NEXT_PUBLIC_APP_NAME= Dev
NEXT_PUBLIC_APP_URL=http://localhost:3004

# Agent (optional). If unset, chat falls back to a no-LLM helper response.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Deploy target: "live" ---
# Local dev: host=local copies to apps/public-site/ (simulates public_html).
# Production: set host, user, and docroot to your Hostinger SSH + public_html path.
DEPLOY_LIVE_HOST=local
DEPLOY_LIVE_PORT=22
DEPLOY_LIVE_USER=
DEPLOY_LIVE_SSH_KEY=~/.ssh/id_ed25519
DEPLOY_LIVE_SSH_PASSPHRASE=
# Defaults to <monorepo>/apps/public-site when unset (local). On server: /home/USER/public_html
DEPLOY_LIVE_DOCROOT=
