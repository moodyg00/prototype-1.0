# Auth — set AUTH_REQUIRED=false locally to skip login (reuses @prototype/auth)
AUTH_REQUIRED=false
AUTH_SECRET=
AUTH_COOKIE_DOMAIN=

# Database
DATABASE_URL=postgresql://grant@localhost:5432/proto2
DIRECT_DATABASE_URL=postgresql://grant@localhost:5432/proto2

# This app name and URL
NEXT_PUBLIC_APP_NAME= Dev
NEXT_PUBLIC_APP_URL=http://localhost:3004

# Agent (optional). If unset, chat falls back to a no-LLM helper response.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Deploy target: "live" (www docroot on the same Hostinger account) ---
# SSH key auth only. Point DEPLOY_LIVE_SSH_KEY at a PRIVATE key path.
DEPLOY_LIVE_HOST=
DEPLOY_LIVE_PORT=22
DEPLOY_LIVE_USER=
DEPLOY_LIVE_SSH_KEY=~/.ssh/id_ed25519
# Passphrase only if your key is encrypted
DEPLOY_LIVE_SSH_PASSPHRASE=
# Absolute path to the live web docroot on the remote host
DEPLOY_LIVE_DOCROOT=/home/USER/public_html
