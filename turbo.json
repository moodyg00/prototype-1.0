{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "pnpm-lock.yaml",
    "packages/tsconfig/**",
    "packages/db/prisma/schema.prisma"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "generated/**"],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md", "!**/.agents/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md", "!**/.agents/**"]
    }
  }
}